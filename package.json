{
  "name": "ouro-apps-site",
  "version": "0.1.0",
  "private": true,
  "description": "Static app distribution site for ouro.bot.",
  "scripts": {
    "build": "node scripts/check-site.mjs && node scripts/build-dist.mjs",
    "test": "node scripts/check-site.mjs",
    "deploy": "npm run build && npx wrangler pages deploy dist --project-name ouro-apps-site --branch main",
    "render:hero": "node scripts/render-hero.mjs",
    "refresh:ouro-md": "node scripts/refresh-ouromd-release.mjs",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "test-ui": "npm run build-storybook && node scripts/a11y.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/html-vite": "^10.4.6",
    "axe-playwright": "^2.2.2",
    "jsdom": "^27.3.0",
    "storybook": "^10.4.6",
    "vite": "^8.1.3"
  }
}
