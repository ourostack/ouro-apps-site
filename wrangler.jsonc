{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ouro-apps-site-router",
  "main": "worker.js",
  "compatibility_date": "2026-07-02",
  "routes": [
    { "pattern": "ouro.bot/apps/*", "zone_name": "ouro.bot" },
    { "pattern": "ouro.bot/assets/*", "zone_name": "ouro.bot" },
    { "pattern": "ouro.bot/styles.css", "zone_name": "ouro.bot" },
    { "pattern": "ouro.bot/ouro-md-install.sh", "zone_name": "ouro.bot" }
  ]
}
